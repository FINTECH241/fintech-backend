# ===================================================================
# MODÈLE DE CONFIGURATION
# Copiez ce fichier en ".env" et remplacez les valeurs.
# Le fichier .env réel ne doit JAMAIS être commité sur GitHub.
# ===================================================================

# --- Base de données PostgreSQL ---
DB_USER=fintech_user
DB_PASSWORD=changez_ce_mot_de_passe
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fintech_gabon

# --- Sécurité de l'API ---
# Générez une clé avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=remplacez_par_une_cle_aleatoire_longue
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Environnement ---
ENVIRONMENT=development
